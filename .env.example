############################
# Application
############################

APP_TZ=
# Optional - default scheduler timezone for jobs; example: America/New_York.

JUBILY_API_BASE_URL=
# Optional - legacy fallback public API URL; prefer PUBLIC_API_BASE_URL; example: https://api.example.com.

NODE_ENV=development
# Required for all environments - runtime mode; use development, test, or production.

OFFERS_SEED_FILE=
# Optional - path to offers seed JSON for scripts/seed-offers.ts; example: data/offers.seed.json.

PORT=3000
# Optional - HTTP port for the NestJS server; defaults to 3000.

API_URL=
# Production only - public backend URL; example: https://api.example.com.

FRONTEND_URL=
# Production only - public frontend URL used for account email links; example: https://app.example.com.

PUBLIC_API_BASE_URL=
# Production only - public backend URL used for tracking, callbacks, and asset links; example: https://api.example.com.

############################
# Database
############################

DATABASE_URL=
# Production only - PostgreSQL connection string for Prisma; example: postgresql://user:pass@host:5432/db.

############################
# Authentication
############################

EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
# Optional - email verification token lifetime in minutes; defaults to 1440.

JWT_EXPIRES=
# Optional - legacy JWT expiry fallback; prefer JWT_EXPIRES_IN; example: 1d.

JWT_EXPIRES_IN=1d
# Optional - JWT access token lifetime; example: 15m, 1h, or 1d.

JWT_SECRET=
# Required for all environments - JWT signing secret; minimum 32 characters.

PASSWORD_RESET_TOKEN_TTL_MINUTES=60
# Optional - password reset token lifetime in minutes; defaults to 60.

REFRESH_TOKEN_TTL_DAYS=30
# Optional - refresh token lifetime in days; defaults to 30.

SETTINGS_MASTER_KEY_BASE64=
# Production only - base64 encoded 32-byte key for encrypted integration settings.

############################
# Admin
############################

ADMIN_EMAIL=
# Optional - email used by scripts/create-admin.ts when --email is omitted.

ADMIN_EMAILS=
# Production only - comma-separated admin allowlist for platform/admin access.

ADMIN_PASSWORD=
# Optional - password used by scripts/create-admin.ts when --password is omitted.

############################
# Workspace / SaaS
############################

PUBLISH_MAX_ATTEMPTS=6
# Optional - maximum publish worker attempts before giving up; defaults to 6.

WORKER_LOCK_TTL_MS=1800000
# Optional - stale worker lock timeout in milliseconds; defaults to 1800000.

WORKERS_ENABLED=true
# Optional - enables render and publish workers; defaults to true outside tests.

WORKSPACE_TRIAL_DAYS=0
# Optional - number of trial days for newly created workspace subscriptions; defaults to 0.

############################
# Email (Resend / SMTP)
############################

EMAIL_OUTBOX_BATCH_SIZE=10
# Optional - max outbox emails processed per retry batch; defaults to 10 and caps at 50.

EMAIL_OUTBOX_MAX_ATTEMPTS=5
# Optional - max retry attempts for failed outbox email delivery; defaults to 5.

EMAIL_PROVIDER=log
# Production only - email delivery provider; required in production; allowed values: log, smtp, resend.

FROM_EMAIL=
# Production only - sender email for account emails; required when email delivery is configured.

FROM_NAME=Jubily
# Production only - sender display name for account emails; required when email delivery is configured.

RESEND_API_KEY=
# Optional - Resend API key; required when EMAIL_PROVIDER=resend.

SMTP_HOST=
# Optional - SMTP server hostname; required when EMAIL_PROVIDER=smtp.

SMTP_PASSWORD=
# Optional - SMTP password; required when EMAIL_PROVIDER=smtp.

SMTP_PORT=587
# Optional - SMTP TCP port; required when EMAIL_PROVIDER=smtp.

SMTP_SECURE=false
# Optional - whether SMTP uses TLS from connect; required when EMAIL_PROVIDER=smtp; true or false.

SMTP_USER=
# Optional - SMTP username; required when EMAIL_PROVIDER=smtp.

############################
# YouTube OAuth
############################

YOUTUBE_ADMIN_REDIRECT_URI=
# Production only - admin YouTube OAuth callback URL; example: https://api.example.com/admin/auth/youtube/callback.

YOUTUBE_ALLOW_FILE_TOKEN_FALLBACK=false
# Optional - permits legacy YouTube token file writes if encrypted DB persistence fails; true or false.

YOUTUBE_CAPTION_LANG=en
# Optional - language code for uploaded YouTube captions; defaults to en.

YOUTUBE_CHANNEL_ID=
# Optional - legacy alias for target YouTube channel ID; prefer YOUTUBE_TARGET_CHANNEL_ID.

YOUTUBE_CLIENT_ID=
# Production only - Google OAuth client ID for YouTube OAuth.

YOUTUBE_CLIENT_SECRET=
# Production only - Google OAuth client secret for YouTube OAuth.

YOUTUBE_CUSTOMER_REDIRECT_URI=
# Production only - customer workspace YouTube OAuth callback URL; example: https://api.example.com/workspaces/youtube/callback.

YOUTUBE_PRIVACY=unlisted
# Optional - privacy status for uploaded YouTube videos; example: private, unlisted, or public.

YOUTUBE_REDIRECT=
# Optional - legacy non-production YouTube OAuth callback URL fallback; example: http://localhost:3000/auth/youtube/callback.

YOUTUBE_TARGET_CHANNEL_ID=
# Optional - expected admin YouTube channel ID; blocks global uploads to the wrong channel when set.

############################
# OpenAI
############################

AI_MODE=live
# Optional - script/topic AI mode; use live or mock.

IMAGE_AI_MODE=live
# Optional - image generation mode; use live or mock.

MOCK_SCENE_IMAGE_URL=
# Optional - fallback scene image URL used in mock mode or image failure paths.

MOCK_THUMBNAIL_IMAGE_URL=
# Optional - fallback thumbnail image URL used in mock image mode.

OPENAI_API_KEY=
# Production only - OpenAI API key for script, topic, and image generation.

############################
# Shotstack
############################

CLOUDINARY_API_KEY=
# Optional - Cloudinary API key for generated image, audio, and video asset uploads.

CLOUDINARY_API_SECRET=
# Optional - Cloudinary API secret for generated image, audio, and video asset uploads.

CLOUDINARY_CLOUD_NAME=
# Optional - Cloudinary cloud name for generated image, audio, and video asset uploads.

CLOUDINARY_FOLDER=automation
# Optional - Cloudinary folder for generated assets; defaults vary by service.

DEBUG_SHOTSTACK_PAYLOAD=false
# Optional - writes Shotstack render payload JSON files under tmp/shotstack-payloads when true.

GOOGLE_TTS_KEY_FILE=
# Optional - Google Cloud Text-to-Speech service account file path; required when TTS_MODE is live and ADC is unavailable.

GOOGLE_TTS_LANG=en-US
# Optional - Google TTS language code; defaults to en-US.

GOOGLE_TTS_PITCH=0
# Optional - Google TTS pitch value; defaults to 0.

GOOGLE_TTS_RATE=1.0
# Optional - Google TTS speaking rate; defaults to 1.0.

GOOGLE_TTS_VOICE=en-US-Studio-O
# Optional - Google TTS voice name; defaults to en-US-Studio-O.

GOOGLE_TTS_WORDS_PER_SECOND=2.2
# Optional - narration timing estimate used for TTS scene breaks; defaults to 2.2.

MOCK_VOICEOVER_URL=
# Optional - voiceover URL required when TTS_MODE=mock.

MUSIC_CALM=
# Optional - background music URL selected for calm or anxiety/stress topics.

MUSIC_DEFAULT=
# Optional - default background music URL when no mood-specific music matches.

MUSIC_SOFT=
# Optional - background music URL selected for sleep or night topics.

MUSIC_UPBEAT=
# Optional - background music URL selected for energy or morning topics.

SFX_POP=
# Optional - short sound effect URL layered into generated videos.

SHOTSTACK_API_KEY=
# Production only - Shotstack API key for rendering videos.

SHOTSTACK_OWNER_ID=
# Production only - Shotstack owner/account identifier required by env validation.

TTS_MODE=live
# Optional - text-to-speech mode; use live or mock.

VIDEO_TARGET_SECONDS=75
# Optional - target generated video duration in seconds; valid production target is 60-90.

############################
# Billing
############################

BILLING_RETURN_BASE_URL=
# Optional - base URL for billing success/cancel redirects; falls back to PUBLIC_API_BASE_URL.

BILLING_WEBHOOK_SECRET=
# Optional - shared HMAC secret for generic billing webhooks.

############################
# Stripe
############################

STRIPE_ENABLED=false
# Optional - enables Stripe checkout and webhook handling; true or false.

STRIPE_PREMIUM_MONTHLY_PRICE_ID=
# Optional - Stripe Premium monthly price ID; required when STRIPE_ENABLED=true.

STRIPE_PREMIUM_YEARLY_PRICE_ID=
# Optional - Stripe Premium yearly price ID; required when STRIPE_ENABLED=true.

STRIPE_PRO_MONTHLY_PRICE_ID=
# Optional - Stripe Pro monthly price ID; required when STRIPE_ENABLED=true.

STRIPE_PRO_YEARLY_PRICE_ID=
# Optional - Stripe Pro yearly price ID; required when STRIPE_ENABLED=true.

STRIPE_SECRET_KEY=
# Optional - Stripe secret API key; required when STRIPE_ENABLED=true.

STRIPE_WEBHOOK_SECRET=
# Optional - Stripe webhook signing secret for /billing/webhooks/stripe; required when STRIPE_ENABLED=true.

############################
# Paystack
############################

PAYSTACK_ENABLED=false
# Optional - enables Paystack checkout and webhook handling; true or false.

PAYSTACK_PREMIUM_MONTHLY_PLAN_CODE=
# Optional - Paystack Premium monthly plan code; required when PAYSTACK_ENABLED=true.

PAYSTACK_PREMIUM_YEARLY_PLAN_CODE=
# Optional - Paystack Premium yearly plan code; required when PAYSTACK_ENABLED=true.

PAYSTACK_PRO_MONTHLY_PLAN_CODE=
# Optional - Paystack Pro monthly plan code; required when PAYSTACK_ENABLED=true.

PAYSTACK_PRO_YEARLY_PLAN_CODE=
# Optional - Paystack Pro yearly plan code; required when PAYSTACK_ENABLED=true.

PAYSTACK_SECRET_KEY=
# Optional - Paystack secret API key; required when PAYSTACK_ENABLED=true.

PAYSTACK_WEBHOOK_SECRET=
# Optional - Paystack webhook signing secret; falls back to PAYSTACK_SECRET_KEY if unset.

############################
# Tracking
############################

AFFILIATE_CLICK_PARAM=
# Optional - extra affiliate click query parameter appended to tracking URLs; example: subid.

GOOGLE_SHEET_ID=
# Optional - Google Sheet ID for tracking/log export integrations.

SHEETS_MAX_LOG_ROWS=5000
# Optional - maximum tracking log rows retained in Google Sheets; defaults to 5000.

SHEETS_TRIM_BATCH=500
# Optional - number of oldest Google Sheets rows deleted per trim batch; defaults to 500.

############################
# Affiliate Providers
############################

CLICKBANK_INS_ENABLED=true
# Optional - enforces ClickBank INS secret verification; defaults to true.

CLICKBANK_INS_SECRET=
# Optional - ClickBank INS secret; required when CLICKBANK_INS_ENABLED=true.

DIGISTORE24_ALLOW_UNSIGNED=false
# Optional - allows unsigned Digistore24 IPN payloads; use only for local testing.

DIGISTORE24_IPN_PASSPHRASE=
# Optional - Digistore24 IPN passphrase for signature verification; required unless unsigned IPNs are allowed.

DIGISTORE24_PRODUCT_MAP=
# Optional - JSON object mapping Digistore24 product IDs to internal plan or offer metadata.

############################
# Frontend URLs
############################

APP_WEB_URL=
# Optional - legacy frontend URL fallback for account email links; prefer FRONTEND_URL.

PUBLIC_APP_URL=
# Optional - legacy frontend URL fallback for account email links; example: https://app.example.com.

############################
# Monitoring / Logging
############################

# No dedicated monitoring or logging environment variables are currently read.

############################
# Feature Flags
############################

TOPIC_INGEST_AI_FALLBACK_COUNT=25
# Optional - number of AI topics generated when RSS pending topics are below threshold.

TOPIC_INGEST_CRON=0 */3 * * *
# Optional - cron schedule for topic ingestion; defaults to every 3 hours.

TOPIC_INGEST_DEBUG_DATES=false
# Optional - logs RSS item date parsing diagnostics when true.

TOPIC_INGEST_ENABLED=true
# Optional - enables scheduled topic ingestion; true or false.

TOPIC_INGEST_FRESH_HOURS=72
# Optional - RSS item freshness window in hours; defaults to 72.

TOPIC_INGEST_MAX_PER_RUN=30
# Optional - max RSS topics created per ingestion run; defaults to 30.

TOPIC_INGEST_MIN_PENDING=20
# Optional - pending topic threshold before AI fallback runs; defaults to 20.

TOPIC_INGEST_TZ=America/New_York
# Optional - timezone for topic ingestion cron; defaults to America/New_York.

TOPIC_RSS_REWRITE=true
# Optional - rewrites RSS titles into topic-style titles; true or false.

TOPIC_RSS_URLS=
# Optional - comma-separated RSS feed URLs for topic ingestion.
