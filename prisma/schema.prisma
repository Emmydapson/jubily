generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Topic {
  id          String      @id @default(uuid())
  workspaceId String?
  title       String
  source      String
  score       Int
  status      TopicStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scripts   Script[]
  videos    Video[]
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

enum TopicStatus {
  PENDING
  USED
  REJECTED
}

model Script {
  id                   String    @id @default(uuid())
  workspaceId          String?
  topicId              String
  promptVer            String
  content              String
  outputHash           String
  reviewStatus         String    @default("PENDING")
  qualityScore         Int?
  qualityReview        Json?
  titleCandidates      Json?
  selectedTitle        String?
  youtubeDescription   String?
  hashtags             String[]  @default([])
  thumbnailPrompt      String?
  thumbnailImageUrl    String?
  thumbnailStatus      String    @default("PENDING")
  thumbnailError       String?
  thumbnailGeneratedAt DateTime?
  rewriteAttempts      Int       @default(0)
  createdAt            DateTime  @default(now())

  topic     Topic      @relation(fields: [topicId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  videos    Video[]
  videoJobs VideoJob[] // 👈 ADD THIS

  @@index([workspaceId])
}

model Video {
  id       String @id @default(uuid())
  topicId  String
  scriptId String

  videoUrl String
  format   String
  duration Int
  status   VideoStatus @default(READY)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic          Topic           @relation(fields: [topicId], references: [id])
  script         Script          @relation(fields: [scriptId], references: [id])
  publishResults PublishResult[]
}

enum VideoStatus {
  READY
  PUBLISHED
  FAILED
}

model PublishResult {
  id             String    @id @default(uuid())
  videoId        String
  platform       String
  platformPostId String
  status         String
  errorMessage   String?
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())

  video Video @relation(fields: [videoId], references: [id])
}

enum RunSlot {
  MORNING
  AFTERNOON
  EVENING
}

model VideoJob {
  id                        String             @id @default(uuid())
  workspaceId               String?
  scriptId                  String
  offerId                   String? // ✅ NEW (store product used for the video)
  status                    String             @default("PENDING")
  provider                  String? // 'shotstack' | 'replicate'
  videoUrl                  String?
  youtubeVideoId            String?
  publishTarget             PublishingProvider @default(YOUTUBE)
  socialPostId              String?
  socialPostUrl             String?
  publishStage              String? // optional: UPLOADED | METADATA_DONE | CAPTIONS_DONE
  renderId                  String?
  error                     String?
  youtubeUrl                String?
  slot                      RunSlot
  scheduledFor              DateTime
  published                 Boolean            @default(false)
  attempts                  Int                @default(0)
  createdAt                 DateTime           @default(now())
  videoSrt                  String?
  workerLockedAt            DateTime?
  workerLockedBy            String?
  workerStage               String?
  thumbnailPrompt           String?
  thumbnailImageUrl         String?
  thumbnailStatus           String             @default("PENDING")
  thumbnailError            String?
  thumbnailGeneratedAt      DateTime?
  durationSeconds           Float?
  sceneCount                Int?
  hasBurnedSubtitles        Boolean            @default(false)
  hasTrackingLink           Boolean            @default(false)
  shotstackPayloadDebugPath String?

  script    Script     @relation(fields: [scriptId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  offer     Offer?     @relation(fields: [offerId], references: [id]) // ✅ NEW relation

  clicks      Click[]
  conversions Conversion[]

  // ✅ NEW: enforce “one job per slot per day”
  @@unique([workspaceId, slot, scheduledFor])
  @@index([status, published])
  @@index([workspaceId])
  @@index([renderId])
  @@index([scriptId])
  @@index([offerId])
  @@index([youtubeVideoId])
  @@index([publishTarget, published])
  @@index([workerStage, workerLockedAt])
}

model Offer {
  id                String       @id @default(uuid())
  workspaceId       String?
  network           String       @default("DIGISTORE24")
  externalProductId String?
  name              String
  nicheTag          String?
  hoplink           String // your affiliate link or promo link base
  active            Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  clicks            Click[]
  conversions       Conversion[]
  videoJobs         VideoJob[]
  workspace         Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, externalProductId])
  @@unique([workspaceId, network, hoplink])
  @@index([workspaceId])
}

model Click {
  id          String     @id @default(uuid())
  workspaceId String?
  offerId     String
  offer       Offer      @relation(fields: [offerId], references: [id])
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  videoJobId String?
  videoJob   VideoJob? @relation(fields: [videoJobId], references: [id], onDelete: SetNull)

  youtubeId String?
  source    String?
  createdAt DateTime @default(now())
  userAgent String?
  ip        String?

  @@index([offerId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([videoJobId])
}

model Conversion {
  id          String     @id @default(uuid())
  workspaceId String?
  offerId     String
  offer       Offer      @relation(fields: [offerId], references: [id])
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  clickId    String?
  videoJobId String?
  videoJob   VideoJob? @relation(fields: [videoJobId], references: [id], onDelete: SetNull)

  event String?

  amount    Float?
  currency  String?
  raw       Json?
  createdAt DateTime @default(now())

  @@index([offerId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([clickId])
  @@index([videoJobId])
}

enum IntegrationProvider {
  GOOGLE
  OPENAI
  DIGISTORE
  CLICKBANK
  YOUTUBE
  TIKTOK
  FACEBOOK
  INSTAGRAM
  SHOTSTACK
}

enum PublishingProvider {
  YOUTUBE
  TIKTOK
  FACEBOOK
  INSTAGRAM
}

enum PipelineStage {
  IMAGE_GENERATION
  RENDER
  PUBLISH
  TRACKING
  CONVERSION
}

enum PipelineSeverity {
  INFO
  WARN
  ERROR
}

model PipelineEvent {
  id          String           @id @default(uuid())
  workspaceId String?
  stage       PipelineStage
  severity    PipelineSeverity @default(INFO)
  status      String
  message     String
  jobId       String?
  offerId     String?
  clickId     String?
  topicId     String?
  scriptId    String?
  provider    String?
  meta        Json?
  createdAt   DateTime         @default(now())
  workspace   Workspace?       @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([stage, createdAt])
  @@index([workspaceId, createdAt])
  @@index([severity, createdAt])
  @@index([status, createdAt])
  @@index([jobId, createdAt])
  @@index([offerId, createdAt])
  @@index([clickId, createdAt])
}

model AppSettings {
  id                String  @id @default("app") // singleton row
  automationEnabled Boolean @default(true)
  verticalEnabled   Boolean @default(true)
  autoPublish       Boolean @default(true)

  timezone     String @default("America/New_York")
  videosPerDay Int    @default(3)

  // store 3 daily run hours (0-23) in the chosen timezone
  runHours Int[] @default([9, 13, 18])

  updatedAt DateTime @updatedAt
}

model IntegrationKey {
  id       String              @id @default(uuid())
  provider IntegrationProvider @unique

  // encrypted blob (AES-256-GCM)
  encrypted String

  // for UI masking: "....ABCD"
  last4 String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  SUPPORT
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  active       Boolean   @default(true)
  lastLoginAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  promoCodes PromoCode[] @relation("PromoCodeCreator")
}

model User {
  id                      String    @id @default(uuid())
  email                   String    @unique
  passwordHash            String
  name                    String?
  active                  Boolean   @default(true)
  emailVerified           Boolean   @default(false)
  emailVerifiedAt         DateTime?
  acceptedTermsAt         DateTime?
  acceptedPrivacyPolicyAt DateTime?
  termsVersion            String?
  privacyPolicyVersion    String?
  passwordChangedAt       DateTime?
  lastLoginAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  memberships             WorkspaceMember[]
  ownedWorkspaces         Workspace[]              @relation("WorkspaceOwner")
  invitesSent             WorkspaceInvite[]        @relation("WorkspaceInviteSender")
  auditLogs               AuditLog[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  sessions                UserSession[]
  promoAttributions       PromoAttribution[]
  socialAccounts          SocialAccount[]
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  rotatedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Workspace {
  id                   String    @id @default(uuid())
  name                 String
  slug                 String?   @unique
  ownerId              String?
  countryCode          String?
  countryName          String?
  affiliateNiches      String[]  @default([])
  affiliatePlatforms   String[]  @default([])
  primaryAffiliateLink String?
  affiliateLinks       Json?
  preferredContentTone String?
  preferredLanguage    String?
  targetAudience       String?
  contentGoal          String?
  suspended            Boolean   @default(false)
  suspendedAt          DateTime?
  suspensionReason     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  owner              User?                        @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members            WorkspaceMember[]
  invites            WorkspaceInvite[]
  subscription       WorkspaceSubscription?
  usages             WorkspaceUsage[]
  youtubeConnections WorkspaceYoutubeConnection[]
  topics             Topic[]
  scripts            Script[]
  offers             Offer[]
  videoJobs          VideoJob[]
  clicks             Click[]
  conversions        Conversion[]
  pipelineEvents     PipelineEvent[]
  auditLogs          AuditLog[]
  promoAttributions  PromoAttribution[]
  socialAccounts     SocialAccount[]
}

model SocialAccount {
  id                                 String             @id @default(uuid())
  workspaceId                        String
  userId                             String
  provider                           PublishingProvider
  providerAccountId                  String
  displayName                        String
  username                           String?
  avatarUrl                          String?
  accessTokenEncrypted               String
  accessTokenLast4                   String
  refreshTokenEncrypted              String?
  refreshTokenLast4                  String?
  expiresAt                          DateTime?
  scopes                             String[]           @default([])
  selectedPageId                     String?
  selectedInstagramBusinessAccountId String?
  metadata                           Json?
  connectedAt                        DateTime           @default(now())
  updatedAt                          DateTime           @updatedAt
  disconnectedAt                     DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider, providerAccountId])
  @@index([workspaceId, provider])
  @@index([userId])
  @@index([disconnectedAt])
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id          String        @id @default(uuid())
  workspaceId String
  email       String
  role        WorkspaceRole @default(MEMBER)
  tokenHash   String        @unique
  invitedById String?
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime      @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User?     @relation("WorkspaceInviteSender", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([email])
}

model WorkspaceYoutubeConnection {
  id               String   @id @default(uuid())
  workspaceId      String   @unique
  encrypted        String
  last4            String
  channelId        String?
  channelTitle     String?
  channelCustomUrl String?
  scope            String?
  connectedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum Plan {
  FREE
  PRO
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingProvider {
  PAYSTACK
  STRIPE
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PromoDiscountType {
  PERCENTAGE
  FIXED
  NONE
}

enum PromoAppliesToPlan {
  PRO
  PREMIUM
  ALL
}

enum PromoAttributionStatus {
  SIGNUP
  CHECKOUT_STARTED
  SUBSCRIBED
  FAILED
  CANCELLED
}

enum PromoDiscountDuration {
  ONE_TIME
}

enum PromoRegionScope {
  ALL
  GLOBAL
  AFRICA
  NIGERIA
  CUSTOM_COUNTRIES
}

enum PaystackDiscountMode {
  TRACKING_ONLY
  ONE_TIME_AMOUNT_DISCOUNT
  UNSUPPORTED
}

model PromoCode {
  id                    String                @id @default(uuid())
  code                  String                @unique
  influencerName        String
  influencerEmail       String?
  description           String?
  discountType          PromoDiscountType     @default(NONE)
  discountValue         Float?
  discountDuration      PromoDiscountDuration @default(ONE_TIME)
  appliesToPlans        PromoAppliesToPlan    @default(ALL)
  regionScope           PromoRegionScope      @default(ALL)
  allowedCountries      String[]              @default([])
  stripePromotionCodeId String?
  stripeCouponId        String?
  paystackDiscountMode  PaystackDiscountMode  @default(UNSUPPORTED)
  maxRedemptions        Int?
  redemptionCount       Int                   @default(0)
  startsAt              DateTime?
  expiresAt             DateTime?
  isActive              Boolean               @default(true)
  createdByAdminId      String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  createdByAdmin AdminUser?         @relation("PromoCodeCreator", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  attributions   PromoAttribution[]

  @@index([isActive])
  @@index([createdByAdminId])
  @@index([createdAt])
}

model PromoAttribution {
  id               String                 @id @default(uuid())
  promoCodeId      String
  userId           String
  workspaceId      String?
  subscriptionId   String?
  provider         BillingProvider?
  plan             Plan?
  interval         BillingInterval?
  amount           Float?
  originalAmount   Float?
  discountAmount   Float?
  finalAmount      Float?
  renewalAmount    Float?
  currency         String?
  countryCode      String?
  regionScope      PromoRegionScope?
  discountDuration PromoDiscountDuration?
  redeemedAt       DateTime?
  status           PromoAttributionStatus
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  promoCode    PromoCode              @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace?             @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  subscription WorkspaceSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([promoCodeId, status])
  @@index([promoCodeId, userId, status])
  @@index([promoCodeId, workspaceId, status])
  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([subscriptionId])
  @@index([provider, createdAt])
}

model WorkspaceSubscription {
  id                     String             @id @default(uuid())
  workspaceId            String             @unique
  plan                   Plan               @default(FREE)
  status                 SubscriptionStatus @default(ACTIVE)
  billingProvider        BillingProvider?
  providerCustomerId     String?
  providerSubscriptionId String?
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  cancelAtPeriodEnd      Boolean            @default(false)
  trialEndsAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  promoAttributions PromoAttribution[]

  @@index([plan])
  @@index([status])
  @@index([billingProvider])
  @@index([currentPeriodEnd])
}

model WorkspaceUsage {
  id               String   @id @default(uuid())
  workspaceId      String
  periodStart      DateTime
  periodEnd        DateTime
  videoGenerations Int      @default(0)
  publishes        Int      @default(0)
  aiGenerations    Int      @default(0)
  renderMinutes    Float    @default(0)
  storageBytes     BigInt   @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, periodStart])
  @@index([workspaceId, periodEnd])
}

enum AuditAction {
  LOGIN
  LOGIN_FAILED
  SIGNUP
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PASSWORD_CHANGED
  REFRESH_TOKEN_ROTATED
  LOGOUT
  LOGOUT_ALL
  SCRIPT_UPDATED
  WORKSPACE_CREATED
  YOUTUBE_CONNECTED
  YOUTUBE_DISCONNECTED
  SOCIAL_ACCOUNT_CONNECTED
  SOCIAL_ACCOUNT_DISCONNECTED
  SOCIAL_ACCOUNT_SELECTED
  VIDEO_GENERATED
  VIDEO_RENDERED
  VIDEO_PUBLISHED
  BILLING_CHECKOUT_REQUESTED
  BILLING_CANCEL_REQUESTED
  SUBSCRIPTION_CHANGED
  WORKSPACE_SUSPENDED
  WORKSPACE_UNSUSPENDED
  PERMISSION_DENIED
}

model AuditLog {
  id          String      @id @default(uuid())
  workspaceId String?
  userId      String?
  adminId     String?
  action      AuditAction
  targetType  String?
  targetId    String?
  ip          String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime    @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([userId, createdAt])
  @@index([adminId, createdAt])
  @@index([action, createdAt])
}

model BillingWebhookEvent {
  id              String    @id @default(uuid())
  provider        String
  providerEventId String
  eventType       String?
  status          String    @default("RECEIVED")
  payload         Json?
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?

  @@unique([provider, providerEventId])
  @@index([provider, receivedAt])
  @@index([status, receivedAt])
}

model OAuthState {
  id          String    @id @default(uuid())
  stateHash   String    @unique
  purpose     String
  workspaceId String?
  userId      String?
  adminId     String?
  adminEmail  String?
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([purpose, expiresAt])
  @@index([workspaceId])
  @@index([userId])
  @@index([adminId])
}

model EmailOutbox {
  id                String    @id @default(uuid())
  userId            String?
  to                String
  type              String
  subject           String
  text              String
  html              String
  status            String    @default("PENDING")
  attempts          Int       @default(0)
  lastError         String?
  providerMessageId String?
  nextAttemptAt     DateTime?
  sentAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([status, nextAttemptAt])
  @@index([userId, createdAt])
  @@index([to, createdAt])
}

model GeneratedImage {
  id         String   @id @default(cuid())
  promptHash String   @unique
  imageUrl   String
  createdAt  DateTime @default(now())
  promptText String
}
